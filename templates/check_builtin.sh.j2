#!/bin/bash
# {{ ansible_managed }}
# built-in check script for VRRP instance {{ item.name }}

set -e

log() {
    echo "$*" | systemd-cat -p info -t keepalived_{{ item.name }}
}

{% if item.maint_file | default('') != '' %}
if [ -e "{{ item.maint_file }}" ] ; then
    log "maintenance mode active"
    exit 1
fi
{% endif %}

{% set checks = item.builtin_checks | default({}) %}
{% if checks.dns_dig | default(false) %}
if ! dig +short +timeout=1 @127.0.0.1 {{ checks.dns_dig_host | default('localhost') }} > /dev/null 2>&1 ; then
    log "dns check failed for {{ checks.dns_dig_host | default('localhost') }}"
    exit 1
fi
{% endif %}

{% if checks.http_health | default(false) %}
HTTP_CODE="$(curl --connect-timeout {{ checks.http_health_timeout | default(0.2) }} -s -o /dev/null -w "%{http_code}" {{ checks.http_health_url }} 2> /dev/null || true)"
if [ "$HTTP_CODE" != "200" ] ; then
    log "http check failed for {{ checks.http_health_url }} (got ${HTTP_CODE})"
    exit 1
fi
{% endif %}

exit 0
